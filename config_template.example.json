{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "proxyDns",
        "address": "tls://8.8.8.8",
        "detour": "proxy"
      },
      {
        "tag": "localDnsPrimary",
        "address": "10.10.0.21",
        "detour": "direct"
      },
      {
        "tag": "localDnsSecondary",
        "address": "10.10.2.21",
        "detour": "direct"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          "chatgpt.com",
          "openai.com",
          "oaistatic.com",
          "google.com",
          "gstatic.com",
          "googleapis.com",
          "googleusercontent.com",
          "github.com",
          "githubusercontent.com",
          "githubassets.com",
          "githubstatus.com",
          "github.io",
          "cursor.sh"
        ],
        "server": "proxyDns"
      }
    ],
    "final": "localDnsPrimary",
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "sb-tun",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "stack": "system",
      "mtu": 1500,
      "auto_route": true,
      "auto_redirect": false,
      "strict_route": true,
      "sniff": true,
      "sniff_override_destination": true
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "type": "selector",
      "outbounds": ["auto", "direct", "{all}"]
    },
    {
      "tag": "auto",
      "type": "urltest",
      "outbounds": ["{all}"],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "10m",
      "tolerance": 50
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "direct",
    "rules": [
      {
        "domain_suffix": [
          "chatgpt.com",
          "openai.com",
          "oaistatic.com",
          "google.com",
          "gstatic.com",
          "googleapis.com",
          "googleusercontent.com",
          "github.com",
          "githubusercontent.com",
          "githubassets.com",
          "githubstatus.com",
          "github.io",
          "cursor.sh"
        ],
        "outbound": "proxy"
      },
      {
        "geoip": ["private"],
        "outbound": "direct"
      }
    ]
  }
}
