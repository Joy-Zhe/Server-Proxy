# Clash 订阅 URL (用于 update-subscription.sh 和 crontab)
# 复制为 .env 并填入你的订阅地址: cp .env.example .env
SUBSCRIPTION_URL=https://subscription.example.invalid/subscribe?token=replace-me
SUBSCRIPTION_UA=Mozilla/5.0
RUN_MODE=tun
ENABLE_LOCAL_PROXY=true
LOCAL_HTTP_PORT=7897
LOCAL_SOCKS_PORT=7891
CLASH_API_HOST=0.0.0.0:9090
CLASH_API_SECRET=replace-with-a-random-secret
TUN_INTERFACE_NAME=sb-tun
TUN_IPV4_CIDR=172.19.0.1/30
TUN_IPV6_CIDR=fdfe:dcba:9876::1/126
TUN_MTU=1500
TUN_AUTO_REDIRECT=false
